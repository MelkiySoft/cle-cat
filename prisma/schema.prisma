generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  //url       = env("DATABASE_URL")
  //directUrl = env("DIRECT_URL")
}

// =============================================
// ENUMS
// =============================================
enum Role {
  CUSTOMER
  PROVIDER
  ADMIN
}

enum CompanyStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
}

// =============================================
// MODELS
// =============================================

model User {
  id             String   @id @default(cuid())
  supabaseAuthId String?  @unique // связь с Supabase Auth.users
  email          String   @unique
  role           Role     @default(CUSTOMER)
  isActive       Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile            Profile?
  companies          Company[]
  requestsAsCustomer Request[] @relation("CustomerRequests")

  // Для модерации компаний
  moderatedCompanies Company[] @relation("CompanyModeration")

  @@map("users")
}

model Profile {
  id        String  @id @default(cuid())
  userId    String  @unique
  firstName String?
  lastName  String?
  phone     String?
  avatarUrl String?
  city      String?
  state     String?

  isActive Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Language {
  id          String   @id @default(cuid())
  code        String   @unique // ru, en, es
  name        String
  locale      String
  image       String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("languages")
}

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  parentId    String?
  image       String?
  top         Boolean  @default(false)
  column      Int      @default(1)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  noindex     Boolean  @default(false)

  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryHierarchy")
  companies Company[]  // legacy, будет через CompanyToCategory
  path      CategoryPath[]
  descriptions CategoryDescription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

model CategoryDescription {
  id              String   @id @default(cuid())
  categoryId      String
  languageCode    String

  name            String
  description     String?
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  metaH1          String?

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, languageCode])
  @@map("category_descriptions")
}

model CategoryPath {
  categoryId String
  pathId     String
  level      Int

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([categoryId, pathId])
  @@map("category_paths")
}

model Information {
  id          String   @id @default(cuid())
  slug        String   @unique
  sortOrder   Int      @default(0)
  isBottom    Boolean  @default(false)
  isActive    Boolean  @default(true)
  noindex     Boolean  @default(false)

  descriptions InformationDescription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("informations")
}

model InformationDescription {
  id              String   @id @default(cuid())
  informationId   String
  languageCode    String

  title           String
  description     String?
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  metaH1          String?

  information Information @relation(fields: [informationId], references: [id], onDelete: Cascade)

  @@unique([informationId, languageCode])
  @@map("information_descriptions")
}

model Company {
  id          String        @id @default(cuid())
  slug        String        @unique
  status      CompanyStatus @default(PENDING)

  name        String
  description String?
  logoUrl     String?
  address     String?
  city        String
  state       String
  phone       String?
  website     String?
  email       String?

  sortOrder   Int      @default(0)
  viewed      Int      @default(0)
  noindex     Boolean  @default(false)
  isActive    Boolean  @default(false)   // только после одобрения + оплаты

  ownerId     String
  owner       User   @relation(fields: [ownerId], references: [id])

  // Много-категорийность
  categoryLinks CompanyToCategory[]
  images        CompanyImage[]
  descriptions  CompanyDescription[]
  requests      Request[]

  // Модерация
  moderationComment String?
  moderatedAt       DateTime?
  moderatedById     String?
  moderatedBy       User?   @relation("CompanyModeration", fields: [moderatedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("companies")
}

model CompanyToCategory {
  companyId  String
  categoryId String
  isMain     Boolean @default(false)

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@id([companyId, categoryId])
  @@map("company_to_categories")
}

model CompanyDescription {
  id              String   @id @default(cuid())
  companyId       String
  languageCode    String

  name            String
  description     String?
  tag             String?
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  metaH1          String?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, languageCode])
  @@map("company_descriptions")
}

model CompanyImage {
  id        String  @id @default(cuid())
  companyId String
  imageUrl  String
  sortOrder Int     @default(0)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_images")
}

model Request {
  id            String        @id @default(cuid())
  message       String?
  preferredDate DateTime?
  status        RequestStatus @default(PENDING)

  acceptedAt   DateTime?
  completedAt  DateTime?

  customerId String
  customer   User   @relation("CustomerRequests", fields: [customerId], references: [id])

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("requests")
}